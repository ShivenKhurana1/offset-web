---
import Layout from "../layouts/Layout.astro";

const tiers = [
  {
    name: "The Sketchbook",
    pigments: "15 Pigments",
    blurb: "Raw, chaotic, handwritten.",
  },
  {
    name: "The Blueprint",
    pigments: "30 Pigments",
    blurb: "Grid layouts, structure, clean.",
  },
  {
    name: "The Overprint",
    pigments: "50 Pigments",
    blurb: "High-fidelity, custom type, glitch art.",
  },
] as const;

const slackOffsetChannel = "https://hackclub.enterprise.slack.com/archives/C0AK5NQ46M8";
const hackClubSlackJoin = "https://hackclub.com/slack";
---

<Layout
  title="OFFSET: Weekly zine, printed & shipped"
  description="Every week a theme drops. You make an 8-page zine. We print it and ship it to your door. RSVP in #offset on Hack Club Slack."
>
  <div class="bg-grain min-h-dvh overflow-x-clip">
    <a
      href="#main"
      class="focus:bg-ink focus:text-paper sr-only focus:not-sr-only focus:absolute focus:z-50 focus:px-4 focus:py-3 focus:outline-none focus:ring-2 focus:ring-cyan-spot"
      style="top: max(1rem, env(safe-area-inset-top, 0px)); left: max(1rem, env(safe-area-inset-left, 0px));"
    >
      Skip to content
    </a>

    <header class="border-ink/10 relative border-b pt-[max(0px,env(safe-area-inset-top,0px))]">
      <div
        class="font-zine-hand text-magenta-spot pointer-events-none absolute -top-1 right-4 hidden rotate-6 text-lg sm:right-6 sm:block"
        aria-hidden="true"
      >
        weeklies!
      </div>
      <div
        class="mx-auto flex max-w-5xl flex-col gap-3 px-4 py-4 sm:flex-row sm:flex-wrap sm:items-center sm:justify-between sm:gap-3 sm:px-8 sm:py-5"
      >
        <span class="font-display animate-wiggle-hover text-xl font-extrabold tracking-tight">OFFSET</span>
        <a
          href={slackOffsetChannel}
          class="border-ink bg-paper text-ink focus:ring-cyan-spot zine-card inline-flex min-h-11 touch-manipulation items-center justify-center gap-2 rounded-sm border-2 px-4 py-2.5 text-sm font-semibold shadow-[3px_3px_0_var(--ink)] focus:outline-none focus:ring-2 focus:ring-offset-2 sm:min-h-0 sm:w-auto sm:py-1.5 sm:pl-3 sm:pr-3"
          target="_blank"
          rel="noopener noreferrer"
        >
          RSVP in <span class="font-mono text-cyan-spot">#offset</span>
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </header>

    <main id="main">
      <section class="relative overflow-hidden px-4 py-12 sm:px-8 sm:py-24 lg:py-28">
        <div class="pointer-events-none absolute inset-0 opacity-[0.07]" aria-hidden="true">
          <div class="bg-cyan-spot absolute -left-20 top-20 size-72 rounded-full blur-3xl"></div>
          <div class="bg-magenta-spot absolute -right-10 bottom-10 size-80 rounded-full blur-3xl"></div>
        </div>

        <!-- Crop marks -->
        <svg
          class="text-ink/25 pointer-events-none absolute left-2 top-2 size-8 sm:left-6 sm:top-6 sm:size-10"
          viewBox="0 0 40 40"
          fill="none"
          stroke="currentColor"
          stroke-width="1.25"
          aria-hidden="true"
        >
          <path d="M15 0v10M0 15h10M0 0l15 15" />
        </svg>
        <svg
          class="text-ink/25 pointer-events-none absolute right-2 top-2 size-8 sm:right-6 sm:top-6 sm:size-10"
          viewBox="0 0 40 40"
          fill="none"
          stroke="currentColor"
          stroke-width="1.25"
          aria-hidden="true"
        >
          <path d="M25 0v10M40 15h-10M40 0L25 15" />
        </svg>
        <svg
          class="text-ink/25 pointer-events-none absolute bottom-2 left-2 size-8 sm:bottom-6 sm:left-6 sm:size-10"
          viewBox="0 0 40 40"
          fill="none"
          stroke="currentColor"
          stroke-width="1.25"
          aria-hidden="true"
        >
          <path d="M15 40V30M0 25h10M0 40l15-15" />
        </svg>
        <svg
          class="text-ink/25 pointer-events-none absolute bottom-2 right-2 size-8 sm:bottom-6 sm:right-6 sm:size-10"
          viewBox="0 0 40 40"
          fill="none"
          stroke="currentColor"
          stroke-width="1.25"
          aria-hidden="true"
        >
          <path d="M25 40V30M40 25h-10M40 40L25 25" />
        </svg>

        <div class="relative mx-auto max-w-5xl">
          <p
            class="text-ink-muted animate-pop-in mb-6 flex flex-wrap items-center gap-2 text-xs font-semibold uppercase tracking-wide sm:text-sm sm:tracking-widest"
          >
            <svg
              class="text-ink size-5 shrink-0"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.75"
              aria-hidden="true"
            >
              <path
                d="M6 18h12v2H6v-2zm-2-4h16a2 2 0 002-2V8a2 2 0 00-2-2h-3V4H7v2H4a2 2 0 00-2 2v4a2 2 0 002 2z"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
              <path d="M7 14h10"></path>
            </svg>
            Got ink? Got ideas? Got 8 pages in you?
          </p>

          <div class="relative">
            <h1
              class="font-display text-ink mb-4 text-[clamp(1.85rem,8.5vw,2.75rem)] font-extrabold leading-[1.02] tracking-tight sm:mb-4 sm:text-6xl sm:leading-[0.95] lg:text-7xl"
            >
              <span class="animate-pop-in-delay-1 relative inline-block">
                <span
                  class="text-cyan-spot absolute left-[3px] top-[2px] -z-10 opacity-80 mix-blend-multiply select-none"
                  aria-hidden="true"
                >
                  Introducing…
                </span>
                <span class="relative">Introducing…</span>
              </span>
              <br />
              <span class="animate-pop-in-delay-2 relative mt-2 inline-block">
                <span
                  class="text-magenta-spot absolute left-[4px] top-[-2px] -z-10 opacity-75 mix-blend-multiply select-none"
                  aria-hidden="true"
                >
                  OFFSET
                </span>
                <span
                  class="text-cyan-spot absolute left-[-3px] top-[2px] -z-10 opacity-70 mix-blend-multiply select-none"
                  aria-hidden="true"
                >
                  OFFSET
                </span>
                <span class="relative">OFFSET</span>
              </span>
            </h1>
            <div
              class="animate-float-slow mt-5 flex justify-start sm:absolute sm:right-4 sm:top-2 sm:mt-0 sm:justify-end"
              aria-hidden="true"
            >
              <div
                class="border-ink bg-paper text-ink animate-stamp font-display inline-flex rotate-[-6deg] border-2 border-dashed px-3 py-1.5 text-[11px] font-extrabold uppercase tracking-wider shadow-[3px_3px_0_var(--ink)] sm:py-1 sm:text-xs"
              >
                8 pg fold
              </div>
            </div>
          </div>

          <p
            class="text-ink-muted animate-pop-in-delay-3 mt-6 max-w-2xl text-base leading-relaxed sm:mt-8 sm:text-lg md:text-xl"
          >
            Every week, a theme drops. You make an 8-page zine. We print it and ship it straight to your door.
          </p>

          <div
            class="text-ink-muted animate-pop-in-delay-3 mt-5 flex items-start gap-2 text-sm font-medium sm:mt-6 sm:items-center sm:text-base"
          >
            <svg
              class="size-5 shrink-0 text-magenta-spot"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.75"
              aria-hidden="true"
            >
              <path d="M4 6h16v12H4V6z" stroke-linecap="round" stroke-linejoin="round"></path>
              <path d="M4 7l8 6 8-6" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
            <span class="min-w-0 break-words">Physical print. Real mail. No pixels-only cop-out.</span>
          </div>
        </div>
      </section>

      <div class="border-ink/10 relative border-y bg-paper-dark/30 py-4 sm:py-5" aria-hidden="true">
        <div class="bg-halftone absolute inset-0 opacity-[0.12]"></div>
        <p
          class="font-zine-hand text-ink-muted relative px-3 text-center text-balance text-lg leading-snug sm:text-2xl"
        >
          ~~~ fold here · staple spine ~~~
        </p>
        <div
          class="font-display text-ink/20 absolute bottom-1 left-3 hidden text-[9px] font-bold tracking-widest sm:left-4 sm:block sm:text-[10px]"
        >
          VOL ○ ZINE
        </div>
        <div
          class="font-display text-ink/20 absolute bottom-1 right-3 hidden text-[9px] font-bold tracking-widest sm:right-4 sm:block sm:text-[10px]"
        >
          CUT — COPY
        </div>
      </div>

      <section class="border-ink/10 border-y bg-paper-dark/40 px-4 py-12 sm:px-8 sm:py-20">
        <div class="mx-auto grid min-w-0 max-w-5xl gap-10 md:grid-cols-2 md:gap-12">
          <div
            class="border-ink/15 zine-card relative overflow-visible rounded-sm border-2 border-dashed bg-paper p-6 pt-8 sm:p-8 sm:pt-10"
          >
            <div
              class="bg-yellow-spot/45 ring-ink/8 absolute -left-2 -top-3 z-10 h-9 w-28 -rotate-[10deg] shadow-sm ring-1"
              aria-hidden="true"
            ></div>
            <div class="absolute left-1/2 top-0 flex -translate-x-1/2 gap-10 pt-1" aria-hidden="true">
              <span class="bg-ink/75 h-2.5 w-1.5 rounded-[1px]"></span>
              <span class="bg-ink/75 h-2.5 w-1.5 rounded-[1px]"></span>
            </div>
            <div class="mb-4 flex items-center gap-3">
              <svg
                class="size-8 text-cyan-spot"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.75"
                aria-hidden="true"
              >
                <path d="M4 6h16v12H4V6z" stroke-linecap="round" stroke-linejoin="round"></path>
                <path d="M8 10h8M8 14h5" stroke-linecap="round"></path>
              </svg>
              <h2 class="font-display text-2xl font-bold">You ship</h2>
            </div>
            <p class="text-ink-muted leading-relaxed">
              An 8-page zine — sketches, layouts, glitch art, code, whatever. Raw or polished, we don&apos;t care as long
              as it slaps.
            </p>
          </div>
          <div class="border-ink/15 zine-card relative overflow-visible rounded-sm border-2 bg-paper p-6 pt-8 sm:p-8 sm:pt-9">
            <div
              class="bg-cyan-spot/35 ring-ink/8 absolute -right-2 -top-2 z-10 h-8 w-24 rotate-[12deg] shadow-sm ring-1"
              aria-hidden="true"
            ></div>
            <div
              class="border-ink/20 absolute -bottom-2 left-6 right-6 border-t border-dotted"
              aria-hidden="true"
            ></div>
            <div class="mb-4 flex items-center gap-3">
              <svg
                class="size-8 text-magenta-spot"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.75"
                aria-hidden="true"
              >
                <path
                  d="M6 18h12v2H6v-2zm-2-4h16a2 2 0 002-2V8a2 2 0 00-2-2h-3V4H7v2H4a2 2 0 00-2 2v4a2 2 0 002 2z"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
                <path d="M7 14h10"></path>
              </svg>
              <h2 class="font-display text-2xl font-bold">We ship</h2>
            </div>
            <p class="text-ink-muted leading-relaxed">
              Your zine. Physically printed. Mailed to you. Plus <strong class="text-ink font-semibold">Pigments</strong> (our
              points system) to spend in the reward shop.
            </p>
          </div>
        </div>
      </section>

      <section class="px-4 py-12 sm:px-8 sm:py-20" aria-labelledby="tiers-heading">
        <div class="mx-auto max-w-5xl">
          <div class="reveal-self">
            <p class="font-zine-hand text-magenta-spot -mb-1 text-lg sm:text-xl">tear along perf ↓</p>
            <h2 id="tiers-heading" class="font-display text-2xl font-extrabold tracking-tight sm:text-4xl">Tiers</h2>
            <p class="text-ink-muted mt-2 max-w-xl">
              Submit quality that matches your ambition. More polish, more Pigments.
            </p>
          </div>

          <ul class="reveal-stagger mt-10 grid min-w-0 gap-5 sm:grid-cols-3">
            {
              tiers.map((tier, i) => (
                <li class="border-ink/12 hover:border-ink/30 zine-card relative flex min-w-0 flex-col rounded-sm border-2 bg-paper p-5 transition-colors sm:p-6">
                  <div class="text-magenta-spot mb-4">
                    {i === 0 && (
                      <svg class="size-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                        <path d="M4 19.5V5a2 2 0 012-2h12v16H6a2 2 0 00-2 2zM8 7h8M8 11h6" stroke-linecap="round" />
                      </svg>
                    )}
                    {i === 1 && (
                      <svg class="size-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                        <path d="M4 4h16v16H4V4z" />
                        <path d="M4 12h16M12 4v16" />
                      </svg>
                    )}
                    {i === 2 && (
                      <svg class="size-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                        <circle cx="9" cy="12" r="5" />
                        <circle cx="15" cy="12" r="5" opacity="0.6" />
                      </svg>
                    )}
                  </div>
                  <span
                    class="font-display text-ink/25 pointer-events-none absolute right-3 top-2 text-[10px] font-bold"
                    aria-hidden="true"
                  >
                    NO. {String(i + 1).padStart(2, "0")}
                  </span>
                  <h3 class="font-display text-lg font-bold">{tier.name}</h3>
                  <p class="text-cyan-spot mt-2 font-mono text-sm font-semibold">{tier.pigments}</p>
                  <p class="text-ink-muted mt-3 text-sm leading-relaxed">{tier.blurb}</p>
                </li>
              ))
            }
          </ul>
        </div>
      </section>

      <section class="border-ink/10 border-t px-4 py-12 sm:px-8 sm:py-20" aria-labelledby="bonus-heading">
        <div class="mx-auto max-w-5xl">
          <div class="reveal-self">
            <h2 id="bonus-heading" class="font-display text-2xl font-extrabold tracking-tight sm:text-4xl">
              Bonus Pigments
            </h2>
          </div>
          <ul class="reveal-stagger mt-8 grid gap-4 sm:grid-cols-2">
            <li class="border-ink/12 zine-card flex gap-4 rounded-sm border bg-paper p-4 sm:p-5">
              <svg class="text-yellow-spot mt-0.5 size-8 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M13 2L3 14h8l-1 8 10-12h-8l1-8z" />
              </svg>
              <div>
                <p class="font-display font-bold">+5 Flash Dry</p>
                <p class="text-ink-muted mt-1 text-sm">Submit within 48 hours of the theme drop.</p>
              </div>
            </li>
            <li class="border-ink/12 zine-card flex gap-4 rounded-sm border bg-paper p-4 sm:p-5">
              <svg
                class="text-magenta-spot mt-0.5 size-8 shrink-0"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.75"
                aria-hidden="true"
              >
                <path
                  d="M12 22c4.97 0 6-3 6-6 0-4-4-8-6-12-2 4-6 8-6 12 0 3 1.03 6 6 6z"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
              <div>
                <p class="font-display font-bold">+10 Series Streak</p>
                <p class="text-ink-muted mt-1 text-sm">Submit three weeks in a row.</p>
              </div>
            </li>
          </ul>
        </div>
      </section>

      <section class="bg-ink text-paper relative overflow-hidden px-4 py-12 sm:px-8 sm:py-20" aria-labelledby="shop-heading">
        <div class="bg-halftone pointer-events-none absolute inset-0 opacity-[0.07]" aria-hidden="true"></div>
        <div class="reveal-self relative mx-auto max-w-5xl">
          <p class="font-zine-hand text-yellow-spot mb-2 text-xl opacity-90">loot table ↯</p>
          <h2 id="shop-heading" class="font-display text-2xl font-extrabold tracking-tight sm:text-4xl">
            Spend your Pigments on
          </h2>
          <p class="mt-5 text-base leading-relaxed text-balance text-white/85 sm:mt-6 sm:text-lg">
            Ink tank printers · drawing tablets · energy drink grants · the Mega-Zine
            <svg
              class="text-yellow-spot animate-star-pop inline-block size-5 align-[-0.15em]"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d="M12 2l2.4 7.4h7.8l-6.3 4.6 2.4 7.4-6.3-4.6-6.3 4.6 2.4-7.4-6.3-4.6h7.8L12 2z"></path>
            </svg>
          </p>
        </div>
      </section>

      <section class="px-4 py-12 sm:px-8 sm:py-20" aria-labelledby="schedule-heading">
        <div class="mx-auto max-w-5xl">
          <div class="reveal-self">
            <h2 id="schedule-heading" class="font-display text-2xl font-extrabold tracking-tight sm:text-4xl">The rhythm</h2>
            <p class="font-zine-hand text-cyan-spot mt-2 text-balance text-base sm:text-lg">
              same deadline every week — no excuses
            </p>
          </div>
          <dl class="reveal-self mt-8 grid gap-6 sm:grid-cols-3">
            <div class="border-ink/12 border-l-4 border-l-cyan-spot pl-5">
              <dt class="text-ink-muted text-xs font-bold uppercase tracking-wider">Monday</dt>
              <dd class="font-display mt-1 text-lg font-bold">Theme drops</dd>
            </div>
            <div class="border-ink/12 border-l-4 border-l-magenta-spot pl-5">
              <dt class="text-ink-muted text-xs font-bold uppercase tracking-wider">Friday night</dt>
              <dd class="font-display mt-1 text-lg font-bold">Deadline</dd>
            </div>
            <div class="border-ink/12 border-l-4 border-l-yellow-spot pl-5">
              <dt class="text-ink-muted text-xs font-bold uppercase tracking-wider">Following week</dt>
              <dd class="font-display mt-1 text-lg font-bold">Your zine ships</dd>
            </div>
          </dl>
          <p class="text-ink-muted mt-10 flex flex-wrap items-center gap-2 text-lg font-medium">
            Don&apos;t sleep on it.
            <span class="inline-flex items-center gap-1" aria-hidden="true">
              <span class="bg-ink inline-block size-2 rounded-full"></span>
              <span class="bg-ink inline-block size-2 rounded-full"></span>
            </span>
          </p>
        </div>
      </section>

      <section class="border-ink/10 border-t px-4 py-12 sm:px-8 sm:py-20" aria-labelledby="rsvp-heading">
        <div class="reveal-self mx-auto max-w-5xl">
          <p class="font-zine-hand text-magenta-spot mb-2 text-lg">hack club slack</p>
          <h2 id="rsvp-heading" class="font-display text-2xl font-extrabold tracking-tight sm:text-4xl">RSVP in #offset</h2>
          <p class="text-ink-muted mt-3 max-w-xl text-base leading-relaxed text-pretty">
            Join the <a
              href={hackClubSlackJoin}
              class="text-ink touch-manipulation font-semibold underline decoration-cyan-spot decoration-2 underline-offset-2 hover:text-cyan-spot"
              target="_blank"
              rel="noopener noreferrer">Hack Club Slack</a>, then hop into <span class="font-mono font-semibold text-magenta-spot">#offset</span> to RSVP. Full site still cooking — the channel is where it&apos;s happening first.
          </p>
          <div class="mt-6 flex w-full max-w-md flex-col gap-3 sm:max-w-none sm:flex-row sm:flex-wrap">
            <a
              href={slackOffsetChannel}
              class="border-ink bg-magenta-spot text-paper focus:ring-cyan-spot zine-card inline-flex min-h-12 touch-manipulation items-center justify-center gap-2 rounded-sm border-2 px-4 py-3 text-sm font-bold shadow-[4px_4px_0_var(--ink)] focus:outline-none focus:ring-2 focus:ring-offset-2 sm:min-h-0 sm:w-auto sm:py-2.5"
              target="_blank"
              rel="noopener noreferrer"
            >
              Open <span class="font-mono">#offset</span>
              <span aria-hidden="true">→</span>
            </a>
            <a
              href={hackClubSlackJoin}
              class="border-ink/20 text-ink-muted hover:border-ink/40 hover:text-ink focus:ring-cyan-spot inline-flex min-h-12 touch-manipulation items-center justify-center gap-2 rounded-sm border-2 border-dashed bg-transparent px-4 py-3 text-center text-sm font-semibold focus:outline-none focus:ring-2 focus:ring-offset-2 sm:min-h-0 sm:w-auto sm:py-2.5"
              target="_blank"
              rel="noopener noreferrer"
            >
              Join Hack Club Slack first
            </a>
          </div>
          <p class="text-ink-muted mt-6 max-w-md text-sm leading-relaxed">
            OFFSET is a weekly print ritual: one brief, eight pages, your voice on paper.
          </p>
        </div>
      </section>
    </main>

    <footer class="border-ink/10 border-t px-4 py-8 sm:px-8 sm:py-10">
      <div class="mx-auto max-w-5xl">
        <p
          class="font-display animate-pop-in-wide-delay text-ink relative inline-block max-w-full text-lg font-extrabold tracking-tight sm:text-2xl"
        >
          Made by teens, for teens.
          <svg
            class="text-magenta-spot pointer-events-none absolute -bottom-1 left-0 w-full overflow-visible"
            viewBox="0 0 280 12"
            fill="none"
            aria-hidden="true"
          >
            <path
              class="zine-scribble-line"
              d="M4 8c40-6 80 8 120 2s100-10 172 0"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              pathLength="1"></path>
          </svg>
        </p>
        <p class="text-ink-muted mt-4 max-w-md text-sm leading-relaxed">OFFSET — print club energy, in your mailbox.</p>
      </div>
    </footer>

    <noscript>
      <style>
        .reveal-self,
        .reveal-stagger > li {
          opacity: 1 !important;
          transform: none !important;
        }
      </style>
    </noscript>
    <script>
      requestAnimationFrame(() => {
        const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        const singles = document.querySelectorAll(".reveal-self");
        const lists = document.querySelectorAll(".reveal-stagger");

        function mark(el) {
          if (el.classList.contains("reveal-stagger")) el.classList.add("is-inview");
          else el.classList.add("is-visible");
        }

        if (reduce) {
          singles.forEach(mark);
          lists.forEach(mark);
          return;
        }

        const narrow = window.matchMedia("(max-width: 639px)").matches;
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (!e.isIntersecting) continue;
              mark(e.target);
              io.unobserve(e.target);
            }
          },
          {
            rootMargin: narrow ? "0px 0px -2% 0px" : "0px 0px -7% 0px",
            threshold: narrow ? 0.04 : 0.06,
          },
        );

        singles.forEach((el) => io.observe(el));
        lists.forEach((el) => io.observe(el));
      });
    </script>
  </div>
</Layout>
